{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"],
      "@@/*": ["./src/.umi/*"],
      "@rc-component/input-number": ["./src/index.ts"]
    },
    "strict": false,
    "module": "ESNext"
  },
  "include": ["global.d.ts", ".fatherrc.ts", ".dumirc.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "lib", "es", "dist", "docs-dist", ".dumi/tmp"]
}
